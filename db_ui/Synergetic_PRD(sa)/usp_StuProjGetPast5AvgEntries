alter PROCEDURE [dbo].[usp_StuProjGetPast5AvgEntries]  

AS  
  DECLARE 
      @cy int = YEAR(GETDATE());

  SELECT @cy = FileYear FROM FileSemesters WHERE SystemCurrentFlag = 1;

  WITH cte as (
    SELECT
      ps.LastYearLevel
      , c.Gender
    FROM PastStudents ps
      INNER JOIN Community c on c.ID = ps.ID
    WHERE year(ps.EntryDate) BETWEEN @cy-5 and @cy-1 
    UNION ALL
    SELECT
    s.EntryYearLevel
    , c.Gender
    FROM Students s
      INNER JOIN Community c on c.ID = s.ID
    WHERE YEAR(s.EntryDate) BETWEEN @cy-5 and @cy-1 
  )
  SELECT 
    l.YearLevelSort
    ,  SUM(case cte.Gender when 'F' then 1 else 0 end)  as 'Female Total Entries'
    ,  SUM(case cte.Gender when 'M' then 1 else 0 end)  as 'Male Total Entries'

  FROM cte
    LEFT JOIN luYearLevel l on l.Code = cte.LastYearLevel
    GROUP BY l.YearLevelSort
    ORDER BY l.YearLevelSort

GO

